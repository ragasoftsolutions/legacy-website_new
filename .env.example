# Payment Gateway - N-Genius
# Keep these on server-side (Vercel project env), do not expose with VITE_
NGENIUS_API_KEY=your_ngenius_api_key_here
NGENIUS_OUTLET_REF=your_outlet_reference_here
NGENIUS_BASE_URL=https://api-gateway.ngenius-payments.com
NGENIUS_CURRENCY=AED

# Public display value in frontend
VITE_NGENIUS_CURRENCY=AED

# Optional local-only fallback: set true only for Vite dev proxy testing
VITE_USE_NGENIUS_DEV_PROXY=false

# Redirect URLs registered in N-Genius dashboard
PAYMENT_SUCCESS_URL=https://yourdomain.com/payment-success
PAYMENT_CANCEL_URL=https://yourdomain.com/payment-cancel

# Email Configuration - Brevo (Sendinblue)
# Get your API key from: https://app.brevo.com/settings/keys/api
VITE_BREVO_API_KEY=your_brevo_api_key_here
VITE_EMAIL_FROM=noreply@yourdomain.com
VITE_EMAIL_FROM_NAME=Your Company Name
VITE_EMAIL_TO=recipient@example.com
